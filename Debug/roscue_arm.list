0800106c <mcp_cs_low>:
#define MCP_RX1IF       0x02U  // RX buffer 1 수신 완료 flag
#define MCP_RX0IE       0x01U  // RX buffer 0 interrupt enable bit
#define MCP_RX1IE       0x02U  // RX buffer 1 interrupt enable bit
